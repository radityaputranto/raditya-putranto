# ==============================================================
# SUPABASE
# Dashboard: https://supabase.com/dashboard/project/<project-ref>
# ==============================================================

# Project URL (Settings > API > Project URL)
SUPABASE_URL=https://<project-ref>.supabase.co

# Anon/Public Key (Settings > API > Project API Keys > anon public)
SUPABASE_KEY=your-anon-key-here

# ==============================================================
# GOOGLE SHEETS (opsional - untuk contact form)
# Panduan: https://developers.google.com/sheets/api/quickstart/nodejs
# ==============================================================

# Email akun service Google Cloud
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com

# Private key dari file credentials JSON (ganti \n dengan baris baru)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ID Google Spreadsheet (dari URL: docs.google.com/spreadsheets/d/<ID>)
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here
